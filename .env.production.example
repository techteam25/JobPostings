# =============================================================================
# Production Environment Variables for docker-compose.prod.yml
# =============================================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# =============================================================================

# --- Container Images (GHCR) ---
BACKEND_IMAGE=ghcr.io/OWNER/jobpostings-backend:latest
FRONTEND_IMAGE=ghcr.io/OWNER/jobpostings-frontend:latest

# --- Backend: Server ---
PORT=5500
NODE_ENV=production
SERVER_URL=https://api.getinvolved.team
FRONTEND_URL=https://site.getinvolved.team
HOST=0.0.0.0

# --- Backend: Database (MySQL) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=jobpostings
DB_USER=your_db_user
DB_PASSWORD=your_db_password
MYSQL_ROOT_PASSWORD=your_root_password

# --- Backend: JWT ---
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# --- Backend: Redis ---
# In Docker, services communicate on internal port 6379 via container names
REDIS_CACHE_PWD=your-redis-cache-password
REDIS_QUEUE_PWD=your-redis-queue-password
REDIS_RATE_LIMITER_PWD=your-redis-rate-limiter-password
REDIS_CACHE_URL=redis://:your-redis-cache-password@redis-cache:6379
REDIS_QUEUE_URL=redis://:your-redis-queue-password@redis-queue:6379
REDIS_RATE_LIMITER_URL=redis://:your-redis-rate-limiter-password@redis-rate-limiter:6379

# --- Backend: Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@getinvolved.team

# --- Backend: Authentication ---
BETTER_AUTH_SECRET=your-better-auth-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# --- Backend: Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id
# Path inside the container (mounted via docker-compose volume)
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/firebase-sa.json

# --- Backend: Typesense ---
TYPESENSE_API_KEY=your-typesense-api-key
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# --- Backend: Logging ---
LOG_LEVEL=info

# --- Frontend ---
# These are also passed as Docker build args (baked into the client bundle)
NEXT_PUBLIC_SERVER_URL=https://api.getinvolved.team/api
NEXT_PUBLIC_FRONTEND_URL=https://site.getinvolved.team

# --- Certbot ---
CERTBOT_EMAIL=your-email@example.com
